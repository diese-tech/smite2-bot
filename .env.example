# Runtime modes:
# - Bot-only mode: DISCORD_TOKEN required. Run: python bot.py
# - Web API only (local dev): PORT optional. Run: python web_api/server.py
#   Note: protected endpoints require GODFORGE_ADMIN_PASSWORD.
# - Combined Railway mode: all vars required. Run: python railway_app.py
# WARNING: GODFORGE_ADMIN_PASSWORD=change_me_for_dashboard is a placeholder; change it or dashboard auth will fail.

# Copy this to .env and fill in your values.
# Bot token: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Betting system channel IDs (right-click channel → Copy ID in Discord)
BETTING_LEDGER_CHANNEL_ID=1499551914398842900   # #betting-ledger
PLACE_BETS_CHANNEL_ID=1499552266611458209       # #place-bets
MATCH_DRAFT_CHANNEL_ID=0                        # handshake channel; 0 = fallback to any channel named *handshake*

# Activity backend for the draft system
ACTIVITY_BACKEND_URL=                           # e.g. https://your-backend.example.com
ACTIVITY_API_KEY=                               # API key for the Activity backend

# Temporary private dashboard gate. Replace with Discord OAuth later.
GODFORGE_ADMIN_PASSWORD=change_me_for_dashboard
