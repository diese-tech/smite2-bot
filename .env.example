# Copy this to .env and fill in your values.
# Bot token: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# Betting system channel IDs (right-click channel → Copy ID in Discord)
BETTING_LEDGER_CHANNEL_ID=0   # #betting-ledger  — persistent paginated embed
PLACE_BETS_CHANNEL_ID=0       # #place-bets       — only channel where .bet works
